PORT=8080
HOST=0.0.0.0
DATABASE_URL=postgres://campusdesk:campusdesk@localhost:5432/campusdesk?sslmode=disable
JWT_SECRET=change-me-in-production

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxx
EMAIL_FROM=noreply@yourschool.com
EMAIL_FROM_NAME=CampusDesk

# Storage (AWS S3 or MinIO)
S3_ENDPOINT=           # leave blank for AWS, set to e.g. localhost:9000 for MinIO
S3_REGION=ap-south-1
S3_BUCKET=campusdesk
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_USE_SSL=true

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v19.0
